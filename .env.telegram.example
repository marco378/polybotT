# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_CHAT_IDS=123456789

# Botlogic integration
BOTLOGIC_PATH=botlogic.py
PYTHON_BIN=python3
CMD_TIMEOUT_SEC=240

# Snapshot defaults
SNAPSHOT_TOP_N=10
SNAPSHOT_TTL_HOURS=2

# Local state/log paths (for Railway use /app/data/...)
STATE_FILE=state.json
MANUAL_LOG_FILE=manual_execution.log
TELEGRAM_RUNTIME_STATE=telegram_runtime_state.json
